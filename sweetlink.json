{
  "appLabel": "Shipkit",
  "appUrl": "http://localhost:3000",
  "prodUrl": "https://shipkit.io",
  "daemonUrl": "https://localhost:4455",
  "healthChecks": {
    "paths": ["/api/health"]
  },
  "smokeRoutes": {
    "defaults": [
      "/",
      "/dashboard",
      "/docs",
      "/blog",
      "/examples",
      "/bones"
    ],
    "presets": {
      "admin": [
        "/admin",
        "/admin/users",
        "/admin/deployments",
        "/admin/projects",
        "/admin/teams"
      ],
      "auth": [
        "/sign-in",
        "/sign-up"
      ],
      "kit": [
        "/",
        "/docs",
        "/examples",
        "/bones"
      ]
    }
  },
  "servers": [
    {
      "env": "dev",
      "start": ["bun", "dev"],
      "check": ["curl", "--fail", "--silent", "http://localhost:3000"],
      "timeoutMs": 60000,
      "cwd": "."
    }
  ]
}
